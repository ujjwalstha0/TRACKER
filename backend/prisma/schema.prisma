generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Price {
  id        BigInt    @id @default(autoincrement())
  symbol    String    @unique @db.VarChar(20)
  company   String?   @db.VarChar(255)
  sector    String?   @db.VarChar(100)
  ltp       Decimal   @db.Decimal(18, 4)
  change    Decimal?  @db.Decimal(18, 4)
  changePct Decimal?  @db.Decimal(10, 4)
  open      Decimal?  @db.Decimal(18, 4)
  high      Decimal?  @db.Decimal(18, 4)
  low       Decimal?  @db.Decimal(18, 4)
  volume    BigInt?
  turnover  Decimal?  @db.Decimal(22, 4)
  savedAt   DateTime  @default(now())

  @@index([savedAt])
}

model PriceCandle {
  id     BigInt   @id @default(autoincrement())
  symbol String   @db.VarChar(20)
  t      DateTime @db.Timestamp(3)
  o      Decimal  @db.Decimal(18, 4)
  h      Decimal  @db.Decimal(18, 4)
  l      Decimal  @db.Decimal(18, 4)
  c      Decimal  @db.Decimal(18, 4)
  v      BigInt?

  @@unique([symbol, t])
  @@index([symbol, t])
  @@index([t])
  @@map("prices")
}

model User {
  id           BigInt    @id @default(autoincrement())
  email        String    @unique @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  displayName  String?   @db.VarChar(120)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  holdings     Holding[]
}

model Holding {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt
  symbol      String    @db.VarChar(20)
  buyPrice    Decimal   @db.Decimal(18, 4)
  qty         Int
  targetPrice Decimal?  @db.Decimal(18, 4)
  stopLoss    Decimal?  @db.Decimal(18, 4)
  notes       String?   @db.VarChar(280)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, symbol])
}

model AuthOtp {
  id        BigInt   @id @default(autoincrement())
  email     String   @db.VarChar(255)
  requestIp String?  @db.VarChar(64)
  purpose   String   @db.VarChar(40)
  codeHash  String   @db.VarChar(128)
  payload   Json?
  attempts  Int      @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email, purpose, createdAt])
  @@index([requestIp, purpose, createdAt])
  @@index([expiresAt])
}

model IndexValue {
  id        BigInt   @id @default(autoincrement())
  indexName String   @unique @db.VarChar(80)
  value     Decimal  @db.Decimal(18, 4)
  change    Decimal  @db.Decimal(18, 4)
  changePct Decimal  @db.Decimal(10, 4)
  savedAt   DateTime @default(now())

  @@index([savedAt])
}

model SignalNotebookEntry {
  id                BigInt   @id @default(autoincrement())
  tradeDate         DateTime @db.Date
  symbol            String   @db.VarChar(20)
  signal            String   @db.VarChar(10)
  confidence        String   @db.VarChar(10)
  entryPrice        Decimal  @db.Decimal(18, 4)
  stopLoss          Decimal  @db.Decimal(18, 4)
  targetPrice       Decimal  @db.Decimal(18, 4)
  riskReward        Decimal  @db.Decimal(10, 4)
  qualityScore      Decimal  @db.Decimal(6, 2)
  reasons           Json
  requiredChecks    Json
  failedChecks      Json
  recommendedAction String   @db.VarChar(80)
  generatedAt       DateTime @default(now())
  evaluatedAt       DateTime?
  closePrice        Decimal? @db.Decimal(18, 4)
  outcome           String   @default("PENDING") @db.VarChar(30)
  accuracyScore     Decimal? @db.Decimal(6, 2)

  @@unique([tradeDate, symbol])
  @@index([tradeDate])
  @@index([tradeDate, evaluatedAt])
}
